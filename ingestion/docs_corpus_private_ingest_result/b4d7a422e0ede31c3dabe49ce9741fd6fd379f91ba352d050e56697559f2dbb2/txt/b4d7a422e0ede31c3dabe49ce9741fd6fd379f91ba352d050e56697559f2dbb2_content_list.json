        "page_idx": 0
    },
    {
        "type": "text",
        "text": "Note 3: It is possible that you may not have any comments, either on the proposed policy or legislation, or may have comments on one and not the other. You may leave a blank column if you either agree to the proposed position, or you have no concerns relating it. ",
        "bbox": [
