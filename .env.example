# Copy to .env and fill in your values
# cp .env.example .env

LEGAL_RAG_SMOKE_MOCK_LLM=0
LEGAL_HYBRID_SKIP_INDEXING=1
LEGAL_HYBRID_ENABLE_RERANK=1

USE_COHERE_EMBEDDINGS=1
USE_OPENAI_EMBEDDINGS=0

LLM_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

HF_TOKEN=test_token

# === Evaluation API (required) ===
EVAL_API_KEY=
EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1

# === LLM / Embeddings ===
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# === Turbopuffer ===
TURBOPUFFER_API_KEY=

# === Reranker (optional; if set, uses API instead of local MiniLM for lower TTFT) ===
VOYAGE_API_KEY=
# Cohere: when set, used for both embeddings (embed-english-v3.0) and reranker
COHERE_API_KEY=
# Optional: Cohere rate limit (default 8 for trial 100k tokens/min; set 90 for production)
# COHERE_RATE_LIMIT_MAX_CALLS=90

# === Legal hybrid pipeline ===
# Skip re-indexing into Turbopuffer (query-only; set to 1 when namespace already populated)
# LEGAL_HYBRID_SKIP_INDEXING=1
# LEGAL_HYBRID_ENABLE_RERANK=0

# Custom API bases (optional):
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_BASE=https://api.openai.com/v1

# === Paths (optional) ===
# SUBMISSION_PATH=submission.json
# CODE_ARCHIVE_PATH=code_archive.zip
# DOCS_DIR=docs_corpus
