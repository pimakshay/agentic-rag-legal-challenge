# Copy to .env and fill in your values
# cp .env.example .env

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

HF_TOKEN=test_token

# === Evaluation API (required) ===
EVAL_API_KEY=
EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1

# === LLM / Embeddings ===
OPENROUTER_API_KEY=
OPENAI_API_KEY=

